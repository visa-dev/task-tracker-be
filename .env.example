# Copy this to `.env` for local reference, or export these as real environment
# variables before running `mvn spring-boot:run` / the Docker container.
# Spring Boot itself reads these via ${VAR_NAME:default} placeholders in
# application.properties - it does not auto-load a .env file.

# --- Database ---
# For local dev: point at a local MySQL. For production: point at your RDS endpoint
# and set DB_USE_SSL=true, DB_SSL_MODE=REQUIRED (RDS enforces/expects SSL by default).
DB_HOST=localhost
DB_PORT=3306
DB_NAME=task_tracker
DB_USERNAME=root
DB_PASSWORD=root
DB_USE_SSL=false
DB_SSL_MODE=DISABLED

# --- JWT ---
# Must be 32+ characters for HS256. CHANGE THIS in any real deployment.
APP_JWT_SECRET=this-is-a-development-only-secret-key-please-change-me-in-prod
APP_JWT_EXPIRATION_MS=3600000

# --- CORS ---
# Comma-separated. Add your Vercel deployment URL(s) here in production, e.g.:
# CORS_ALLOWED_ORIGINS=https://task-tracker.vercel.app,https://task-tracker-git-main-you.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Default Admin Seeding ---
# A default admin account is auto-created on first startup if no admin exists yet
# (see AdminSeeder). Override these before that first run, or change the password
# after logging in either way - don't leave the default in place anywhere but local dev.
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=Admin@123

# --- Server / Profile ---
SERVER_PORT=8080
# dev (default, console logs only) or prod (quieter console + rolling files under LOG_PATH)
SPRING_PROFILES_ACTIVE=dev
LOG_PATH=./logs
