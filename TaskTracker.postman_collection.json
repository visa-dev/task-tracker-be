{
  "info": {
    "name": "TaskTracker",
    "description": "Task Tracker API collection - auth, task CRUD, pagination/filtering, stats, status/assignment, admin user management.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "taskId", "value": "" },
    { "key": "unassignedTaskId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"aliace\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('adminToken', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          },
          "description": "Use an account whose role has been manually set to ROLE_ADMIN in the database (see README)."
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task - self (verify status defaults to IN_PROGRESS)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('a self-created task defaults to IN_PROGRESS, ignoring any client status', function () {",
                  "  pm.expect(json.data.status).to.eql('IN_PROGRESS');",
                  "});",
                  "if (json && json.data && json.data.id) {",
                  "  pm.collectionVariables.set('taskId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/tasks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Write project report\",\n  \"description\": \"Quarterly summary\",\n  \"status\": \"COMPLETED\",\n  \"priority\": \"HIGH\",\n  \"dueDate\": \"2026-08-01\"\n}"
            }
          },
          "description": "Note: 'status' is intentionally sent as COMPLETED to prove the backend ignores it - a self-created task always starts as IN_PROGRESS."
        },
        {
          "name": "Create Task - missing description/dueDate (expect 400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/tasks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Missing required fields\"\n}"
            }
          },
          "description": "description and dueDate are both required - expect a 400 with field-level validation errors."
        },
        {
          "name": "Create Task - Admin, unassigned (goes to Unassigned bucket)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('task is unassigned with no owner', function () {",
                  "  pm.expect(json.data.unassigned).to.eql(true);",
                  "  pm.expect(json.data.ownerId).to.be.null;",
                  "});",
                  "if (json && json.data && json.data.id) {",
                  "  pm.collectionVariables.set('unassignedTaskId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/tasks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Needs an owner\",\n  \"description\": \"Created by an admin without assigning anyone\",\n  \"priority\": \"CRITICAL\",\n  \"dueDate\": \"2026-08-10\"\n}"
            }
          },
          "description": "No ownerId in the body -> the task is created Unassigned, awaiting a later PATCH /tasks/{id}/assign."
        },
        {
          "name": "Assign Unassigned Task to a User (Admin only)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/tasks/{{unassignedTaskId}}/assign",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ownerId\": 1\n}"
            }
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/tasks/{{taskId}}"
          }
        },
        {
          "name": "Get All Tasks (pagination + status/priority filters)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/tasks?page=0&size=10&status=IN_PROGRESS",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "status", "value": "IN_PROGRESS" },
                { "key": "ownerId", "value": "", "disabled": true },
                { "key": "search", "value": "", "disabled": true },
                { "key": "unassigned", "value": "true", "disabled": true },
                { "key": "overdue", "value": "true", "disabled": true }
              ]
            }
          },
          "description": "Enable the disabled query params to try: search=<title text>, unassigned=true (Admin only), overdue=true."
        },
        {
          "name": "Get Stats (includes overdue + unassigned counts)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/tasks/stats"
          }
        },
        {
          "name": "Update Task (full edit)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/tasks/{{taskId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Write project report (updated)\",\n  \"description\": \"Quarterly summary - revised\",\n  \"status\": \"IN_PROGRESS\",\n  \"priority\": \"MEDIUM\",\n  \"dueDate\": \"2026-08-05\"\n}"
            }
          }
        },
        {
          "name": "Update Task Status Only (quick inline change)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/tasks/{{taskId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"COMPLETED\"\n}"
            }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/tasks/{{taskId}}"
          }
        }
      ]
    },
    {
      "name": "Users (Admin)",
      "item": [
        {
          "name": "Get All Users (Admin only, for owner dropdown / user management)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Activate/Deactivate User (Admin only)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/users/2/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"active\": false\n}"
            }
          },
          "description": "Set 'active' to false to deactivate (the user is signed out immediately and can't log back in), or true to reactivate."
        }
      ]
    }
  ]
}
